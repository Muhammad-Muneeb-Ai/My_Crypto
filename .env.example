# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# COINGECKO_API_KEY: Optional. Required for higher rate limits or if the public API is restricted.
# For Demo (Free) keys, use the x-cg-demo-api-key header.
# For Pro keys, use the x-cg-pro-api-key header and pro-api.coingecko.com domain.
COINGECKO_API_KEY=CG-Q91wfGP6X3SRzjeQPxbmB3dG

# COINGECKO_IS_PRO: Optional. Set to "true" to force Pro API mode, "false" to force Demo mode.
# If omitted, it will auto-detect based on the key prefix (Demo keys start with CG-).
COINGECKO_IS_PRO=
